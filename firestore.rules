rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function friendshipDocId(uidA, uidB) {
      return uidA + '_' + uidB;
    }

    function areFriends(uidA, uidB) {
      return (
        exists(/databases/$(database)/documents/friendships/$(friendshipDocId(uidA, uidB))) &&
        get(/databases/$(database)/documents/friendships/$(friendshipDocId(uidA, uidB))).data.status == 'accepted'
      ) || (
        exists(/databases/$(database)/documents/friendships/$(friendshipDocId(uidB, uidA))) &&
        get(/databases/$(database)/documents/friendships/$(friendshipDocId(uidB, uidA))).data.status == 'accepted'
      );
    }

    function validUser(data) {
      return data.uid is string
        && data.username is string
        && data.displayName is string
        && data.avatarUrl is string
        && data.rank is string
        && data.gardenHappiness is number
        && data.totalStars is number;
    }

    function validPost(data) {
      return data.ownerId is string
        && data.photoUrl is string
        && data.plantCommonName is string
        && data.nickname is string
        && data.privacyStatus in ['private', 'public']
        && data.starSum is number
        && data.starCount is number
        && data.trendingScore is number;
    }

    function canReadPostData(data) {
      return data.privacyStatus == 'public' || isOwner(data.ownerId);
    }

    function canCommentPost(postData) {
      return isOwner(postData.ownerId) || areFriends(request.auth.uid, postData.ownerId);
    }

    function validComment(data) {
      return data.authorId is string
        && data.text is string
        && data.type in ['question', 'advice', 'experience']
        && (data.parentCommentId == null || data.parentCommentId is string);
    }

    match /users/{uid} {
      allow read: if true;
      allow create, update: if isOwner(uid) && validUser(request.resource.data);
      allow delete: if false;
    }

    match /posts/{postId} {
      allow read: if canReadPostData(resource.data);

      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.ownerId
        && validPost(request.resource.data);

      allow update: if isSignedIn() && (
        (
          isOwner(resource.data.ownerId)
          && validPost(request.resource.data)
        )
        || (
          request.resource.data.diff(resource.data).changedKeys().hasOnly(['starSum', 'starCount', 'trendingScore'])
          && request.resource.data.ownerId == resource.data.ownerId
          && request.resource.data.privacyStatus == resource.data.privacyStatus
        )
      );

      allow delete: if isOwner(resource.data.ownerId);

      match /comments/{commentId} {
        allow read: if canReadPostData(get(/databases/$(database)/documents/posts/$(postId)).data);

        allow create: if isSignedIn()
          && request.resource.data.authorId == request.auth.uid
          && validComment(request.resource.data)
          && canCommentPost(get(/databases/$(database)/documents/posts/$(postId)).data);

        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }
    }

    match /friendships/{docId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && (
          request.resource.data.requesterId == request.auth.uid
          || request.resource.data.receiverId == request.auth.uid
        )
        && request.resource.data.status in ['pending', 'accepted'];
      allow delete: if false;
    }
  }
}
